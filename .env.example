# Supabase
NUXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only — ห้าม expose ฝั่ง client)
NUXT_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Line Official Account (Messaging API) ---

# ลิงก์เปิด Line OA สำหรับลูกค้า (หน้าร้าน หลังส่งคำขอสำเร็จ)
# จาก Line Developers → Channel → Basic settings → QR code / Line ID → สร้างลิงก์เพิ่มเพื่อน
# ลิงก์เต็ม (ถ้ามีจะใช้ก่อน Line ID)
NUXT_PUBLIC_LINE_OA_URL=https://lin.ee/w5FowCj

# Line ID — แสดงบนหน้าติดต่อ / footer
NUXT_PUBLIC_LINE_OA_ID=LGSub.Official

# รูป QR Line Official
NUXT_PUBLIC_LINE_OA_QR_IMAGE=/images/qrcode_line.jpg

# Channel access token (ยาว) — Messaging API → Channel access token (long-lived)
# ใช้ส่ง Push แจ้งทีมงาน + ตอบข้อความใน webhook
LINE_CHANNEL_ACCESS_TOKEN=

# Channel secret — Basic settings → Channel secret
# ใช้ตรวจลายเซ็น webhook (x-line-signature)
LINE_CHANNEL_SECRET=

# Line user id ของแอดมิน/พนักงานที่จะรับแจ้งเตือนเมื่อมีคำขอใหม่ (คั่นด้วย comma)
# วิธีหา: ให้คนนั้นเพิ่มเพื่อน OA แล้วดู userId ใน server log ตอน webhook event "follow"
# หรือจาก Messaging API → ดูใน webhook payload ฟิลด์ source.userId
LINE_NOTIFY_USER_IDS=

# --- LG Import (Playwright บน VPS / local) ---
# ติดตั้ง: google-chrome-stable, xvfb, npx playwright install chromium && install-deps
# macOS local: ใช้ Chrome แบบ headed อัตโนมัติ (headless มักโดน Akamai → 0 รายการ)
# บน VPS แนะนำ headful + virtual display:
#   Xvfb :99 -screen 0 1366x900x24 &
#   DISPLAY=:99
#   LG_SCRAPE_HEADFUL=1
# บังคับ headless (ไม่แนะนำ): LG_SCRAPE_HEADFUL=0
# LG_SCRAPE_VPS=1          # บังคับใช้ Linux Chrome UA (auto บน linux อยู่แล้ว)
# LG_CHROME_PATH=/usr/bin/google-chrome-stable
# LG_SCRAPE_USER_AGENT=  # override UA เอง
