# Site URL (canonical, OG, sitemap, ลิงก์ในอีเมล) — โดเมนจริงของ production
NUXT_PUBLIC_SITE_URL=https://lgsubscribe-official.com

# Google Search Console — ค่า content จาก meta tag verification
NUXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Tag Manager (ว่าง = ไม่โหลด GTM)
NUXT_PUBLIC_GTM_ID=GTM-WVZWD2CC

# Supabase
NUXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only — ห้าม expose ฝั่ง client)
NUXT_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Line: สองบัญชีคนละบทบาท ---
# หน้าร้าน @LGSub.Official = ลูกค้าติดต่อเซลล์ (โชว์ footer / ติดต่อเรา / QR)
NUXT_PUBLIC_LINE_OA_ID=LGSub.Official
NUXT_PUBLIC_LINE_OA_URL=https://lin.ee/w5FowCj
NUXT_PUBLIC_LINE_OA_QR_IMAGE=/images/qrcode_line.jpg

# หลังบ้าน @subhome = รับแจ้งเตือนงาน (Messaging API — ไม่โชว์บนเว็บ)
NUXT_LINE_CHANNEL_ID=
NUXT_LINE_CHANNEL_SECRET=
NUXT_LINE_CHANNEL_ACCESS_TOKEN=
# User ID พนักงานที่ Add friend @subhome แล้ว (คั่นด้วย comma ถ้าหลายคน)
NUXT_LINE_NOTIFY_USER_ID=

# --- SMTP (ส่ง PDF ตารางผ่อนตะกร้าทางอีเมล) — Brevo ตัวอย่าง ---
# User ต้องเป็น SMTP Login จาก Brevo (เช่น xxxx@smtp-brevo.com) ไม่ใช่อีเมล login บัญชี
# Production: เพิ่ม IP ของ VPS ใน Brevo → Authorized IPs
NUXT_SMTP_HOST=smtp-relay.brevo.com
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=your-id@smtp-brevo.com
NUXT_SMTP_PASS=xsmtpsib-...
NUXT_SMTP_FROM=LG Subscribe <verified-sender@example.com>

# --- ThaiBulkSMS Email (REST API — ไม่ใช้ SMTP) ---
# สร้าง API key ที่ https://dashboard.thaibulksms.com/developer-settings/
# ลงทะเบียน sender + สร้าง template แล้วคัดลอก UUID จาก Email Templates
# ถ้าตั้งครบ ระบบจะใช้ ThaiBulkSMS แทน SMTP อัตโนมัติ
NUXT_THAIBULK_EMAIL_API_KEY=
NUXT_THAIBULK_EMAIL_API_SECRET=
NUXT_THAIBULK_EMAIL_FROM=noreply@yourdomain.com
NUXT_THAIBULK_EMAIL_FROM_NAME=LG Subscribe
# ในเทมเพลตใส่ merge tag {{OPTION_1}} สำหรับข้อความในอีเมล
NUXT_THAIBULK_EMAIL_TEMPLATE_UUID=

# --- LG Import (Playwright บน VPS / local) ---
# ติดตั้ง: google-chrome-stable, xvfb, npx playwright install chromium && install-deps
# macOS local: ใช้ Chrome แบบ headed อัตโนมัติ (headless มักโดน Akamai → 0 รายการ)
# บน VPS แนะนำ headful + virtual display:
#   Xvfb :99 -screen 0 1366x900x24 &
#   DISPLAY=:99
#   LG_SCRAPE_HEADFUL=1
# บังคับ headless (ไม่แนะนำ): LG_SCRAPE_HEADFUL=0
# LG_SCRAPE_VPS=1          # บังคับใช้ Linux Chrome UA (auto บน linux อยู่แล้ว)
# LG_CHROME_PATH=/usr/bin/google-chrome-stable
# LG_SCRAPE_USER_AGENT=  # override UA เอง
